{
  "name": "nextjs-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:celebs:build": "tsc -p tsconfig.scripts.json",
    "seed:celebs:run": "node dist-scripts/scripts/generate_celebrity_edges.js",
    "seed:build": "tsc -p tsconfig.scripts.json",
    "seed:dl-edges:build": "tsc -p tsconfig.scripts.json",
    "seed:dl-edges:run": "node dist-scripts/scripts/seed_dl_edges.js",
    "seed:dl-people:build": "tsc -p tsconfig.scripts.json",
    "seed:dl-people:run": "node dist-scripts/scripts/seed_dl_people.js",
    "seed:dl-org-people:build": "tsc -p tsconfig.scripts.json",
    "seed:celeb-edges:build": "tsc -p tsconfig.scripts.json",
    "seed:celeb-edges:run": "node dist-scripts/scripts/generate_celebrity_edges_v2.js",
    "seed:dl-org-people:run": "node dist-scripts/scripts/seed_dl_org_people.js",
    "seed:env": "npm run seed:build && node dist-scripts/scripts/_env_check.js",
    "seed:peek": "npm run seed:build && node dist-scripts/scripts/_seed_peek.js",
    "seed:gen:kr": "node dist-scripts/scripts/generate_edges_kr_autogen.js",
    "seed:gen:univ-company": "node dist-scripts/scripts/generate_edges_univ_to_company.js",
    "seed:gen:celebrity": "node dist-scripts/scripts/generate_celebrity_edges.js",
    "seed:run": "node dist-scripts/scripts/seed_org_graph.js",
    "seed:all": "npm run seed:build && npm run seed:gen:kr && npm run seed:gen:univ-company && npm run seed:gen:celebrity && npm run seed:run",
    "claude:wait-dev": "powershell -ExecutionPolicy Bypass -File scripts/claude-wait-dev-ready.ps1",
    "claude:smoke-sync-unauth": "powershell -ExecutionPolicy Bypass -File scripts/claude-smoke-sync-unauth.ps1",
    "verify:home-regression": "node scripts/verify-home-regression.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "dotenv": "^17.3.1",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.3",
    "next": "16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "web-push": "^3.6.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/web-push": "^3.6.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0"
  }
}
